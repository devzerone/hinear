// Alert Manager Tests
// Feature: 003-performance-audit (User Story 3: Monitoring)

import { beforeEach, describe, expect, it, vi } from "vitest";

describe("AlertManager", () => {
  beforeEach(() => {
    vi.clearAllMocks();
  });

  describe("checkAlerts()", () => {
    it("should trigger alerts for critical threshold violations", async () => {
      // This test verifies critical alert triggering
      const violations = [
        {
          metricName: "page_load_time",
          thresholdType: "critical",
          currentValue: 5000,
        },
      ];

      const shouldAlert = violations.some(
        (v) => v.thresholdType === "critical"
      );
      expect(shouldAlert).toBe(true);
    });

    it("should trigger alerts for new bottlenecks", async () => {
      // This test verifies bottleneck alerting
      const bottlenecks = [
        { severity: "CRITICAL", status: "IDENTIFIED" },
        { severity: "HIGH", status: "IDENTIFIED" },
      ];

      const shouldAlert = bottlenecks.some(
        (b) => b.severity === "CRITICAL" || b.severity === "HIGH"
      );
      expect(shouldAlert).toBe(true);
    });

    it("should not trigger alerts for resolved issues", async () => {
      // This test verifies resolved issue filtering
      const bottlenecks = [
        { severity: "CRITICAL", status: "RESOLVED" },
        { severity: "HIGH", status: "RESOLVED" },
      ];

      const shouldAlert = bottlenecks.some((b) => b.status !== "RESOLVED");
      expect(shouldAlert).toBe(false);
    });
  });

  describe("sendAlert()", () => {
    it("should route critical alerts to all channels", async () => {
      // This test verifies critical alert routing
      const severity = "CRITICAL";
      const channels = ["console", "email", "webhook"];

      const expectedChannels = severity === "CRITICAL" ? channels : ["console"];
      expect(expectedChannels).toEqual(channels);
    });

    it("should route non-critical alerts to console only", async () => {
      // This test verifies non-critical alert routing
      const severity = "MEDIUM";
      const channels = ["console"];

      const expectedChannels =
        severity === "CRITICAL" ? ["console", "email", "webhook"] : channels;
      expect(expectedChannels).toEqual(channels);
    });

    it("should format alert messages appropriately", async () => {
      // This test verifies alert formatting
      const alert = {
        severity: "CRITICAL",
        title: "Page load time exceeded",
        message: "Current: 5000ms, Critical threshold: 4000ms",
      };

      const formattedMessage = `[${alert.severity}] ${alert.title}: ${alert.message}`;
      expect(formattedMessage).toContain("CRITICAL");
      expect(formattedMessage).toContain("Page load time exceeded");
    });
  });

  describe("getAlertHistory()", () => {
    it("should return alerts within time range", async () => {
      // This test verifies time-range filtering
      const now = new Date();
      const timeRange = {
        start: new Date(now.getTime() - 24 * 60 * 60 * 1000), // 24 hours ago
        end: now,
      };

      const alerts = [
        { timestamp: new Date(now.getTime() - 12 * 60 * 60 * 1000) }, // 12 hours ago
        { timestamp: new Date(now.getTime() - 36 * 60 * 60 * 1000) }, // 36 hours ago
      ];

      const filteredAlerts = alerts.filter(
        (a) => a.timestamp >= timeRange.start && a.timestamp <= timeRange.end
      );

      expect(filteredAlerts).toHaveLength(1);
    });

    it("should return alerts sorted by timestamp (newest first)", async () => {
      // This test verifies sorting
      const alerts = [
        { timestamp: new Date("2026-03-25T10:00:00Z") },
        { timestamp: new Date("2026-03-25T12:00:00Z") },
        { timestamp: new Date("2026-03-25T08:00:00Z") },
      ];

      const sorted = [...alerts].sort(
        (a, b) => b.timestamp.getTime() - a.timestamp.getTime()
      );

      expect(sorted[0].timestamp).toEqual(new Date("2026-03-25T12:00:00Z"));
    });
  });

  describe("alert deduplication", () => {
    it("should prevent duplicate alerts within cooldown period", async () => {
      // This test verifies deduplication logic
      const alertCooldown = 5 * 60 * 1000; // 5 minutes
      const lastAlert = new Date(Date.now() - 2 * 60 * 1000); // 2 minutes ago
      const now = new Date();

      const shouldSendAlert =
        now.getTime() - lastAlert.getTime() > alertCooldown;
      expect(shouldSendAlert).toBe(false); // Still in cooldown
    });

    it("should allow alerts after cooldown period expires", async () => {
      // This test verifies cooldown expiration
      const alertCooldown = 5 * 60 * 1000; // 5 minutes
      const lastAlert = new Date(Date.now() - 6 * 60 * 1000); // 6 minutes ago
      const now = new Date();

      const shouldSendAlert =
        now.getTime() - lastAlert.getTime() > alertCooldown;
      expect(shouldSendAlert).toBe(true); // Cooldown expired
    });

    it("should rate limit non-critical alerts", async () => {
      // This test verifies rate limiting
      const rateLimit = {
        maxAlerts: 3,
        timeWindow: 60 * 60 * 1000, // 1 hour
      };

      const recentAlerts = [
        { timestamp: new Date(Date.now() - 10 * 60 * 1000) },
        { timestamp: new Date(Date.now() - 20 * 60 * 1000) },
        { timestamp: new Date(Date.now() - 30 * 60 * 1000) },
      ];

      const canSendAlert = recentAlerts.length < rateLimit.maxAlerts;
      expect(canSendAlert).toBe(false); // At limit
    });
  });
});
