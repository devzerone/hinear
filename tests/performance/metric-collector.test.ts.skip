// Unit Tests for MetricCollector
// Feature: 003-performance-audit

import { beforeEach, describe, expect, it, vi } from "vitest";
import type { MetricUnit } from "@/features/performance/contracts";
import { MetricCollector } from "@/features/performance/lib/metric-collector";

// Mock performance API
const mockPerformance = {
  mark: vi.fn(),
  measure: vi.fn(),
  getEntriesByName: vi.fn(),
  clearMarks: vi.fn(),
  clearMeasures: vi.fn(),
};

// Mock fetch
global.fetch = vi.fn();

describe("MetricCollector", () => {
  let collector: MetricCollector;

  beforeEach(() => {
    // Setup mocks
    global.performance = mockPerformance as any;
    vi.clearAllMocks();

    collector = new MetricCollector("test-session");
  });

  describe("mark", () => {
    it("should create a performance mark with session ID", () => {
      collector.mark("test-operation");

      expect(mockPerformance.mark).toHaveBeenCalledWith(
        "test-session-test-operation-start"
      );
    });

    it("should handle missing performance API gracefully", () => {
      global.performance = undefined as any;
      const consoleSpy = vi.spyOn(console, "warn").mockImplementation();

      collector.mark("test-operation");

      expect(consoleSpy).toHaveBeenCalledWith(
        "[MetricCollector] Performance API not available"
      );
      consoleSpy.mockRestore();
    });
  });

  describe("measure", () => {
    it("should measure duration from mark to now", () => {
      // Setup mock return value
      mockPerformance.getEntriesByName.mockReturnValue([{ duration: 100 }]);

      const duration = collector.measure("test-operation");

      expect(duration).toBe(100);
      expect(mockPerformance.mark).toHaveBeenCalledWith(
        "test-session-test-operation-end"
      );
      expect(mockPerformance.measure).toHaveBeenCalledWith(
        "test-session-test-operation",
        "test-session-test-operation-start",
        "test-session-test-operation-end"
      );
    });

    it("should clean up marks and measures after measuring", () => {
      mockPerformance.getEntriesByName.mockReturnValue([{ duration: 100 }]);

      collector.measure("test-operation");

      expect(mockPerformance.clearMarks).toHaveBeenCalledWith(
        "test-session-test-operation-start"
      );
      expect(mockPerformance.clearMarks).toHaveBeenCalledWith(
        "test-session-test-operation-end"
      );
      expect(mockPerformance.clearMeasures).toHaveBeenCalledWith(
        "test-session-test-operation"
      );
    });

    it("should store metric in internal map", () => {
      mockPerformance.getEntriesByName.mockReturnValue([{ duration: 150 }]);

      collector.measure("test-operation");
      const metrics = collector.getMetrics();

      expect(metrics["test-operation"]).toBe(150);
    });

    it("should return 0 if performance API is unavailable", () => {
      global.performance = undefined as any;
      const consoleSpy = vi.spyOn(console, "warn").mockImplementation();

      const duration = collector.measure("test-operation");

      expect(duration).toBe(0);
      consoleSpy.mockRestore();
    });
  });

  describe("recordMetric", () => {
    it("should send metric to performance API", async () => {
      (global.fetch as any).mockResolvedValue({
        ok: true,
      });

      await collector.recordMetric("custom_metric", 100, "ms" as MetricUnit);

      expect(global.fetch).toHaveBeenCalledWith(
        "/api/performance/metrics",
        expect.objectContaining({
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: expect.stringContaining("custom_metric"),
        })
      );
    });

    it("should include session duration in metadata", async () => {
      mockPerformance.getEntriesByName.mockReturnValue([{ duration: 500 }]);

      // First measure to establish session duration
      collector.measure("init");

      (global.fetch as any).mockResolvedValue({ ok: true });

      await collector.recordMetric("test", 100, "ms" as MetricUnit);

      const callArgs = (global.fetch as any).mock.calls[0];
      const body = JSON.parse(callArgs[1].body);

      expect(body.metadata.sessionDuration).toBeGreaterThan(0);
    });

    it("should handle API errors gracefully", async () => {
      (global.fetch as any).mockRejectedValue(new Error("Network error"));
      const consoleSpy = vi.spyOn(console, "error").mockImplementation();

      await collector.recordMetric("test", 100, "ms" as MetricUnit);

      expect(consoleSpy).toHaveBeenCalled();
      consoleSpy.mockRestore();
    });

    it("should not throw on API errors", async () => {
      (global.fetch as any).mockRejectedValue(new Error("Network error"));

      await expect(
        collector.recordMetric("test", 100, "ms" as MetricUnit)
      ).resolves.toBeUndefined();
    });
  });

  describe("getMetrics", () => {
    it("should return all collected metrics", () => {
      mockPerformance.getEntriesByName
        .mockReturnValueOnce([{ duration: 100 }])
        .mockReturnValueOnce([{ duration: 200 }])
        .mockReturnValueOnce([{ duration: 150 }]);

      collector.measure("metric1");
      collector.measure("metric2");
      collector.measure("metric3");

      const metrics = collector.getMetrics();

      expect(metrics).toEqual({
        metric1: 100,
        metric2: 200,
        metric3: 150,
      });
    });

    it("should return empty object when no metrics collected", () => {
      const metrics = collector.getMetrics();

      expect(metrics).toEqual({});
    });
  });

  describe("clear", () => {
    it("should clear all collected metrics", () => {
      mockPerformance.getEntriesByName.mockReturnValue([{ duration: 100 }]);

      collector.measure("test");
      expect(collector.getMetrics()).toEqual({ test: 100 });

      collector.clear();
      expect(collector.getMetrics()).toEqual({});
    });
  });

  describe("getSessionId", () => {
    it("should return the session ID", () => {
      const sessionId = collector.getSessionId();

      expect(sessionId).toBe("test-session");
    });
  });

  describe("getSessionDuration", () => {
    it("should return duration since collector creation", () => {
      mockPerformance.getEntriesByName.mockReturnValue([{ duration: 1000 }]);

      const duration = collector.getSessionDuration();

      expect(duration).toBeGreaterThanOrEqual(0);
    });

    it("should return 0 if performance API is unavailable", () => {
      global.performance = undefined as any;

      const duration = collector.getSessionDuration();

      expect(duration).toBe(0);
    });
  });
});
