// Integration Tests for Performance Metrics API
// Feature: 003-performance-audit

import { NextRequest } from "next/server";
import { beforeEach, describe, expect, it } from "vitest";
import { POST } from "@/app/api/performance/metrics/route";

// Mock the recordMetric action
vi.mock("@/features/performance/actions/record-metric-action", () => ({
  recordMetric: vi.fn(),
}));

import { recordMetric } from "@/features/performance/actions/record-metric-action";

describe("POST /api/performance/metrics", () => {
  beforeEach(() => {
    vi.clearAllMocks();
  });

  describe("valid requests", () => {
    it("should record a metric with valid data", async () => {
      const requestBody = {
        name: "page_load_time",
        value: 1500,
        unit: "ms",
        route: "/projects/[id]",
      };

      const request = new NextRequest(
        "http://localhost:3000/api/performance/metrics",
        {
          method: "POST",
          body: JSON.stringify(requestBody),
        }
      );

      (recordMetric as any).mockResolvedValue(undefined);

      const response = await POST(request);

      expect(response.status).toBe(200);
      expect(await response.json()).toEqual({ success: true });
      expect(recordMetric).toHaveBeenCalledWith(
        expect.objectContaining({
          name: "page_load_time",
          value: 1500,
          unit: "ms",
          route: "/projects/[id]",
        })
      );
    });

    it("should record metric with optional metadata", async () => {
      const requestBody = {
        name: "query_duration",
        value: 50,
        unit: "ms",
        metadata: { queryName: "getProject", slow: false },
      };

      const request = new NextRequest(
        "http://localhost:3000/api/performance/metrics",
        {
          method: "POST",
          body: JSON.stringify(requestBody),
        }
      );

      (recordMetric as any).mockResolvedValue(undefined);

      const response = await POST(request);

      expect(response.status).toBe(200);
      expect(recordMetric).toHaveBeenCalledWith(
        expect.objectContaining({
          metadata: { queryName: "getProject", slow: false },
        })
      );
    });

    it("should handle missing optional fields", async () => {
      const requestBody = {
        name: "test_metric",
        value: 100,
        unit: "count",
      };

      const request = new NextRequest(
        "http://localhost:3000/api/performance/metrics",
        {
          method: "POST",
          body: JSON.stringify(requestBody),
        }
      );

      (recordMetric as any).mockResolvedValue(undefined);

      const response = await POST(request);

      expect(response.status).toBe(200);
    });
  });

  describe("validation", () => {
    it("should reject request without name", async () => {
      const requestBody = {
        value: 100,
        unit: "ms",
      };

      const request = new NextRequest(
        "http://localhost:3000/api/performance/metrics",
        {
          method: "POST",
          body: JSON.stringify(requestBody),
        }
      );

      const response = await POST(request);

      expect(response.status).toBe(400);
      expect(await response.json()).toEqual({
        error: "Missing required fields: name, value, unit",
      });
    });

    it("should reject request without value", async () => {
      const requestBody = {
        name: "test",
        unit: "ms",
      };

      const request = new NextRequest(
        "http://localhost:3000/api/performance/metrics",
        {
          method: "POST",
          body: JSON.stringify(requestBody),
        }
      );

      const response = await POST(request);

      expect(response.status).toBe(400);
    });

    it("should reject request without unit", async () => {
      const requestBody = {
        name: "test",
        value: 100,
      };

      const request = new NextRequest(
        "http://localhost:3000/api/performance/metrics",
        {
          method: "POST",
          body: JSON.stringify(requestBody),
        }
      );

      const response = await POST(request);

      expect(response.status).toBe(400);
    });

    it("should reject request with invalid value type", async () => {
      const requestBody = {
        name: "test",
        value: "not a number",
        unit: "ms",
      };

      const request = new NextRequest(
        "http://localhost:3000/api/performance/metrics",
        {
          method: "POST",
          body: JSON.stringify(requestBody),
        }
      );

      const response = await POST(request);

      expect(response.status).toBe(400);
    });
  });

  describe("error handling", () => {
    it("should handle recordMetric errors gracefully", async () => {
      const requestBody = {
        name: "test",
        value: 100,
        unit: "ms",
      };

      const request = new NextRequest(
        "http://localhost:3000/api/performance/metrics",
        {
          method: "POST",
          body: JSON.stringify(requestBody),
        }
      );

      (recordMetric as any).mockRejectedValue(new Error("Database error"));

      const response = await POST(request);

      expect(response.status).toBe(500);
      expect(await response.json()).toEqual({
        error: "Failed to record metric",
      });
    });

    it("should handle malformed JSON", async () => {
      const request = new NextRequest(
        "http://localhost:3000/api/performance/metrics",
        {
          method: "POST",
          body: "invalid json",
        }
      );

      const response = await POST(request);

      expect(response.status).toBe(500);
    });
  });
});
