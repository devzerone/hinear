// Integration Tests for Performance Report API
// Feature: 003-performance-audit

import { NextRequest } from "next/server";
import { beforeEach, describe, expect, it } from "vitest";
import { GET } from "@/app/api/performance/report/route";

// Mock the getPerformanceReport action
vi.mock("@/features/performance/actions/get-performance-report-action", () => ({
  getPerformanceReport: vi.fn(),
}));

import { getPerformanceReport } from "@/features/performance/actions/get-performance-report-action";

describe("GET /api/performance/report", () => {
  beforeEach(() => {
    vi.clearAllMocks();
  });

  describe("valid requests", () => {
    it("should generate performance report with valid time range", async () => {
      const mockReport = {
        id: "report-123",
        generatedAt: new Date(),
        timeRange: {
          start: new Date("2026-01-01"),
          end: new Date("2026-01-02"),
        },
        summary: {
          totalMetrics: 100,
          averagePageLoadTime: 1500,
          slowQueriesCount: 5,
          averageBundleSize: 180,
          webVitals: {
            cls: 0.1,
            fid: 50,
            fcp: 1000,
            lcp: 1500,
            ttfb: 300,
          },
        },
        bottlenecks: [],
        recommendations: [],
      };

      (getPerformanceReport as any).mockResolvedValue(mockReport);

      const url = new URL("http://localhost:3000/api/performance/report");
      url.searchParams.set("start", "2026-01-01T00:00:00Z");
      url.searchParams.set("end", "2026-01-02T00:00:00Z");

      const request = new NextRequest(url);

      const response = await GET(request);

      expect(response.status).toBe(200);
      const json = await response.json();
      expect(json).toEqual(mockReport);
      expect(getPerformanceReport).toHaveBeenCalledWith({
        timeRange: {
          start: new Date("2026-01-01T00:00:00Z"),
          end: new Date("2026-01-02T00:00:00Z"),
        },
      });
    });

    it("should support route filtering", async () => {
      const mockReport = {
        id: "report-456",
        generatedAt: new Date(),
        timeRange: {
          start: new Date("2026-01-01"),
          end: new Date("2026-01-02"),
        },
        summary: {
          totalMetrics: 50,
          averagePageLoadTime: 1200,
          slowQueriesCount: 2,
          averageBundleSize: 150,
          webVitals: {
            cls: 0.05,
            fid: 30,
            fcp: 800,
            lcp: 1200,
            ttfb: 200,
          },
        },
        bottlenecks: [],
        recommendations: [],
      };

      (getPerformanceReport as any).mockResolvedValue(mockReport);

      const url = new URL("http://localhost:3000/api/performance/report");
      url.searchParams.set("start", "2026-01-01T00:00:00Z");
      url.searchParams.set("end", "2026-01-02T00:00:00Z");
      url.searchParams.set("routes", "/projects/[id],/issues/[id]");

      const request = new NextRequest(url);

      const response = await GET(request);

      expect(response.status).toBe(200);
      expect(getPerformanceReport).toHaveBeenCalledWith({
        timeRange: expect.any(Object),
        routes: ["/projects/[id]", "/issues/[id]"],
      });
    });

    it("should support environment filtering", async () => {
      const mockReport = {
        id: "report-789",
        generatedAt: new Date(),
        timeRange: {
          start: new Date("2026-01-01"),
          end: new Date("2026-01-02"),
        },
        summary: {
          totalMetrics: 75,
          averagePageLoadTime: 1300,
          slowQueriesCount: 3,
          averageBundleSize: 160,
          webVitals: {
            cls: 0.08,
            fid: 40,
            fcp: 900,
            lcp: 1300,
            ttfb: 250,
          },
        },
        bottlenecks: [],
        recommendations: [],
      };

      (getPerformanceReport as any).mockResolvedValue(mockReport);

      const url = new URL("http://localhost:3000/api/performance/report");
      url.searchParams.set("start", "2026-01-01T00:00:00Z");
      url.searchParams.set("end", "2026-01-02T00:00:00Z");
      url.searchParams.set("environments", "production");

      const request = new NextRequest(url);

      const response = await GET(request);

      expect(response.status).toBe(200);
      expect(getPerformanceReport).toHaveBeenCalledWith({
        timeRange: expect.any(Object),
        environments: ["production"],
      });
    });
  });

  describe("validation", () => {
    it("should reject request without start time", async () => {
      const url = new URL("http://localhost:3000/api/performance/report");
      url.searchParams.set("end", "2026-01-02T00:00:00Z");

      const request = new NextRequest(url);

      const response = await GET(request);

      expect(response.status).toBe(400);
      expect(await response.json()).toEqual({
        error: "Missing required query params: start, end",
      });
    });

    it("should reject request without end time", async () => {
      const url = new URL("http://localhost:3000/api/performance/report");
      url.searchParams.set("start", "2026-01-01T00:00:00Z");

      const request = new NextRequest(url);

      const response = await GET(request);

      expect(response.status).toBe(400);
      expect(await response.json()).toEqual({
        error: "Missing required query params: start, end",
      });
    });

    it("should handle invalid date format", async () => {
      const url = new URL("http://localhost:3000/api/performance/report");
      url.searchParams.set("start", "invalid-date");
      url.searchParams.set("end", "2026-01-02T00:00:00Z");

      const request = new NextRequest(url);

      const response = await GET(request);

      // Should handle invalid date gracefully
      expect(response.status).toBeGreaterThanOrEqual(400);
    });
  });

  describe("error handling", () => {
    it("should handle getPerformanceReport errors", async () => {
      const url = new URL("http://localhost:3000/api/performance/report");
      url.searchParams.set("start", "2026-01-01T00:00:00Z");
      url.searchParams.set("end", "2026-01-02T00:00:00Z");

      const request = new NextRequest(url);

      (getPerformanceReport as any).mockRejectedValue(
        new Error("Database error")
      );

      const response = await GET(request);

      expect(response.status).toBe(500);
      expect(await response.json()).toEqual({
        error: "Failed to generate performance report",
      });
    });
  });
});
