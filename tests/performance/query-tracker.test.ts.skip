// Unit Tests for Query Tracker
// Feature: 003-performance-audit

import { beforeEach, describe, expect, it, vi } from "vitest";
import { trackQuery } from "@/lib/performance/query-tracker";

// Mock performance API
const mockPerformance = {
  now: vi.fn(),
};

// Mock fetch
global.fetch = vi.fn();

describe("trackQuery", () => {
  beforeEach(() => {
    // Setup mocks
    global.performance = mockPerformance as any;
    vi.clearAllMocks();

    // Default mock for performance.now()
    mockPerformance.now.mockReturnValue(0);
  });

  describe("successful query", () => {
    it("should execute query and return result", async () => {
      const queryFn = async () => ({ data: "test" });
      mockPerformance.now.mockReturnValueOnce(0).mockReturnValueOnce(50);

      const result = await trackQuery("testQuery", queryFn);

      expect(result).toEqual({ data: "test" });
    });

    it("should log slow queries (>200ms)", async () => {
      const queryFn = async () => ({ data: "test" });
      mockPerformance.now.mockReturnValueOnce(0).mockReturnValueOnce(250);
      const consoleSpy = vi.spyOn(console, "warn").mockImplementation();

      await trackQuery("slowQuery", queryFn);

      expect(consoleSpy).toHaveBeenCalledWith(
        "[Slow Query] slowQuery: 250.00ms"
      );
      consoleSpy.mockRestore();
    });

    it("should not log fast queries (<200ms)", async () => {
      const queryFn = async () => ({ data: "test" });
      mockPerformance.now.mockReturnValueOnce(0).mockReturnValueOnce(100);
      const consoleSpy = vi.spyOn(console, "warn").mockImplementation();

      await trackQuery("fastQuery", queryFn);

      expect(consoleSpy).not.toHaveBeenCalled();
      consoleSpy.mockRestore();
    });

    it("should send metric to performance API", async () => {
      const queryFn = async () => ({ data: "test" });
      mockPerformance.now.mockReturnValueOnce(0).mockReturnValueOnce(150);
      (global.fetch as any).mockResolvedValue({ ok: true });

      await trackQuery("testQuery", queryFn);

      expect(global.fetch).toHaveBeenCalledWith(
        "/api/performance/metrics",
        expect.objectContaining({
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: expect.stringContaining("query_duration"),
        })
      );
    });

    it("should include slow query flag in metadata", async () => {
      const queryFn = async () => ({ data: "test" });
      mockPerformance.now.mockReturnValueOnce(0).mockReturnValueOnce(250);
      (global.fetch as any).mockResolvedValue({ ok: true });

      await trackQuery("slowQuery", queryFn);

      const callArgs = (global.fetch as any).mock.calls[0];
      const body = JSON.parse(callArgs[1].body);

      expect(body.metadata.slow).toBe(true);
    });
  });

  describe("failed query", () => {
    it("should throw query errors", async () => {
      const queryFn = async () => {
        throw new Error("Query failed");
      };
      mockPerformance.now.mockReturnValueOnce(0).mockReturnValueOnce(100);

      await expect(trackQuery("failingQuery", queryFn)).rejects.toThrow(
        "Query failed"
      );
    });

    it("should log error queries with duration", async () => {
      const queryFn = async () => {
        throw new Error("Query failed");
      };
      mockPerformance.now.mockReturnValueOnce(0).mockReturnValueOnce(150);
      const consoleSpy = vi.spyOn(console, "error").mockImplementation();

      await expect(trackQuery("failingQuery", queryFn)).rejects.toThrow();

      expect(consoleSpy).toHaveBeenCalledWith(
        "[Query Error] failingQuery: 150.00ms",
        expect.any(Error)
      );
      consoleSpy.mockRestore();
    });
  });

  describe("metric recording", () => {
    it("should fire and forget metric recording", async () => {
      const queryFn = async () => ({ data: "test" });
      mockPerformance.now.mockReturnValueOnce(0).mockReturnValueOnce(100);
      (global.fetch as any).mockRejectedValue(new Error("Network error"));

      // Should not throw even if fetch fails
      await expect(trackQuery("testQuery", queryFn)).resolves.toEqual({
        data: "test",
      });
    });

    it("should not record metrics on server side", async () => {
      const queryFn = async () => ({ data: "test" });
      mockPerformance.now.mockReturnValueOnce(0).mockReturnValueOnce(100);

      // Simulate server side
      const originalWindow = global.window;
      // @ts-expect-error
      delete global.window;

      await trackQuery("testQuery", queryFn);

      // Fetch should not be called on server side
      expect(global.fetch).not.toHaveBeenCalled();

      // Restore window
      global.window = originalWindow;
    });
  });

  describe("performance API unavailable", () => {
    it("should handle missing performance API gracefully", async () => {
      const queryFn = async () => ({ data: "test" });
      global.performance = undefined as any;

      // Should not throw
      await expect(trackQuery("testQuery", queryFn)).resolves.toEqual({
        data: "test",
      });
    });
  });
});
